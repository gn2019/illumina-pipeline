{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com///nextflow_schema.json",
  "title": " pipeline parameters",
  "description": "",
  "type": "object",
  "properties": {
    "tumors": {
      "type": "string",
      "default": "PD29429h_DM3_40,PD29429i_DM3_640"
    },
    "normal": {
      "type": "string",
      "default": "HELA"
    },
    "base": {
      "type": "string",
      "default": "/home/projects/aafek/golann/shoshani"
    },
    "results": {
      "type": "string",
      "default": "/home/projects/aafek/golann/shoshani/ShareScripts/wgs/results"
    },
    "scripts": {
      "type": "string",
      "default": "/home/projects/aafek/golann/shoshani/ShareScripts/wgs"
    },
    "annotate": {
      "type": "string",
      "default": "/home/projects/aafek/golann/shoshani/ShareScripts/wgs/annotate"
    },
    "fastq_dir": {
      "type": "string",
      "default": "/home/projects/aafek/golann/shoshani/ShareScripts/wgs/data/fastq"
    },
    "genome": {
      "type": "string",
      "default": "/home/projects/aafek/golann/shoshani/GRCh38.p7.genome.fa"
    },
    "species": {
      "type": "string",
      "default": "Human"
    },
    "assembly": {
      "type": "string",
      "default": "GRCh38"
    },
    "cgpwgs_sif": {
      "type": "string",
      "default": "/home/projects/aafek/golann/cgpwgs.sif",
      "hidden": true
    },
    "lumpy_env": {
      "type": "string",
      "default": "/home/projects/aafek/golann/.conda/envs/lumpy-sv",
      "hidden": true
    },
    "ampsuite_env": {
      "type": "string",
      "default": "/home/projects/aafek/golann/.conda/envs/ampsuite",
      "hidden": true
    },
    "bw_env": {
      "type": "string",
      "default": "/home/projects/aafek/golann/.conda/envs/bw",
      "hidden": true
    },
    "ascat_gc_correction": {
      "type": "string",
      "default": "~/CNV_SV_ref_GRCh38_hla_decoy_ebv_brass6+/ascat/SnpGcCorrections.tsv",
      "hidden": true
    },
    "caveman_blacklist": {
      "type": "string",
      "default": "~/hg38-blacklist.v2.bed",
      "hidden": true
    },
    "caveman_indels": {
      "type": "string",
      "default": "~/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz",
      "hidden": true
    },
    "ascat_purity": {
      "type": "number",
      "description": "Optional ASCAT purity override, passed to ascat.pl as -pu. Only applied when ascat_ploidy is also set.",
      "hidden": true
    },
    "ascat_ploidy": {
      "type": "number",
      "description": "Optional ASCAT ploidy override, passed to ascat.pl as -pi. Only applied when ascat_purity is also set.",
      "hidden": true
    },
    "follow_ascat_caveman_flow": {
      "type": "boolean",
      "default": true,
      "description": "Feed ASCAT's copy-number output into CaVEMan (-tc/-nc/-k) instead of the flat -td 5 -nd 2 defaults. Automatically falls back to -td/-nd for a pair if ASCAT's per-sample outputs are missing or unusable, even when true."
    }
  }
}
